<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- UDP to the server on the LAN. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Read by UdpTransport to tell "Wi-Fi dropped, wait for it" apart from
         "the server isn't there", so roaming between access points mid-game
         backs off and recovers instead of killing the transport. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- The gamepad is useless without Wi-Fi, so say so rather than letting the
         Play listing imply otherwise. -->
    <uses-feature
        android:name="android.hardware.wifi"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DroidOSS">
        <!--
            configChanges is load-bearing, not a micro-optimisation.

            Entering the pad flips the activity to landscape, and by default
            Android answers a configuration change by destroying and recreating
            the activity. That fires onPause, which sends BYE and drops the
            session, so the pad would disconnect itself the instant it appeared —
            and briefly run two sessions at once while the old transport was
            still shutting down.

            Handling these ourselves keeps one activity, and therefore one
            transport, alive across rotation.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|uiMode|density"
            android:theme="@style/Theme.DroidOSS"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>